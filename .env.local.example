# Supabase project settings (Project Settings > API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# The anon/publishable key (safe-for-client key, but used here server-only
# to run queries as the logged-in user so RLS applies). Never the secret key.
SUPABASE_ANON_KEY=

# Shared secret the Google Apps Script must send in the "x-api-key" header
API_SECRET=
# Optional: set this to the OLD value of API_SECRET while rotating it, so
# callers still using the old secret keep working during the rotation.
# Remove once every caller (Apps Script deployments) has been updated.
API_SECRET_PREVIOUS=

# Shared secret the scheduler must send as "Authorization: Bearer <value>"
# when calling /api/cron/sync. If deploying to Vercel, an env var named
# exactly CRON_SECRET is auto-injected into that header by Vercel Cron Jobs —
# any other scheduler (e.g. GitHub Actions) must send it explicitly.
CRON_SECRET=
# Optional: same rotation mechanism as API_SECRET_PREVIOUS, for CRON_SECRET.
CRON_SECRET_PREVIOUS=

# Google OAuth client (Google Cloud Console > APIs & Services > Credentials
# > Create OAuth client ID > Web application). Each app user connects their
# own Google account through this; spreadsheets are created in *their* own
# Drive, not a shared service account's (see lib/google-oauth.ts and
# lib/google-sheets.ts — this replaced the old service-account approach,
# which always failed for a non-Workspace Gmail user with a Drive storage
# quota error).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must exactly match a redirect URI registered on that OAuth client, e.g.
# https://your-deployed-domain.com/api/google/callback (or
# http://localhost:3000/api/google/callback for local dev).
GOOGLE_OAUTH_REDIRECT_URI=
# 32 random bytes, base64-encoded (e.g. `openssl rand -base64 32`). Encrypts
# refresh tokens at rest in the google_accounts table (see lib/crypto.ts).
# Generate once per environment and keep it — rotating it is destructive:
# every already-connected user's stored token becomes undecryptable and
# they'll need to reconnect.
GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY=
# Optional — the template spreadsheet's file ID (from its URL), shared with
# every connecting user's Google account as at least Viewer. If unset, a
# blank Orders+Config spreadsheet is created from scratch per shop instead.
GOOGLE_SHEETS_TEMPLATE_ID=
