# Supabase project settings (Project Settings > API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# The anon/publishable key (safe-for-client key, but used here server-only
# to run queries as the logged-in user so RLS applies). Never the secret key.
SUPABASE_ANON_KEY=

# Shared secret the Google Apps Script must send in the "x-api-key" header
API_SECRET=

# Google service account used to provision spreadsheets from /shops/new
# (Google Cloud Console > IAM & Admin > Service Accounts > Keys > JSON)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# The template spreadsheet's file ID (from its URL), shared with the
# service account email above as at least Viewer
GOOGLE_SHEETS_TEMPLATE_ID=
